            return code;
        }

        function generateESPSystem(request) {
            let code = `-- ESP Avançado\n`;
            code += `local ESP = {Enabled = false, Players = true, Items = true, Distance = true}\n`;
            code += `VisualTab:CreateToggle("ESP Players", false, function(v) ESP.Players = v end)\n`;
            code += `VisualTab:CreateToggle("ESP Items", false, function(v) ESP.Items = v end)\n`;
            code += `RunService.RenderStepped:Connect(function() -- ESP render logic end)\n\n`;
            return code;
        }

        function generateFlySystem(request) {
            let code = `-- Sistema Fly Profissional\n`;
            code += `local Flying = false\n`;
            code += `local FlySpeed = 50\n`;
            code += `MiscTab:CreateToggle("Fly", false, function(v) Flying = v end)\n`;
            code += `MiscTab:CreateSlider("Fly Speed", 10, 200, 50, function(v) FlySpeed = v end)\n`;
            code += `UserInputService.InputBegan:Connect(function(i,g) if g then return end if i.KeyCode == Enum.KeyCode.Space and Flying then -- fly activation end end)\n\n`;
            return code;
        }

        function generateSpeedSystem(request) {
            let code = `-- Sistema Speed Avançado\n`;
            code += `local SpeedValue = 33.3 -- Evade: 1500 = 33.3\n`;
            code += `MiscTab:CreateSlider("Speed", 16, 200, 33, function(v) SpeedValue = v LocalPlayer.Character.Humanoid.WalkSpeed = v end)\n`;
            code += `if game.PlaceId == 9872472334 then -- Evade specific\n`;
            code += `    SpeedValue = 33.3\n`;
            code += `    -- Strafe modify: 186 -> 670 (+29 speed)\n`;
            code += `    local strafeBoost = 29\n`;
            code += `    RunService.RenderStepped:Connect(function()\n`;
            code += `        local move = LocalPlayer.Character.Humanoid.MoveDirection\n`;
            code += `        if move.X ~= 0 then\n`;
            code += `            local cam = Camera\n`;
            code += `            local strafe = cam.CFrame.RightVector * move.X * strafeBoost\n`;
            code += `            LocalPlayer.Character.HumanoidRootPart.Velocity = LocalPlayer.Character.HumanoidRootPart.Velocity + strafe\n`;
            code += `        end\n`;
            code += `    end)\n`;
            code += `end\n\n`;
            return code;
        }

        function generateStudioSystem(request) {
            let code = `-- [OWNER EXCLUSIVE] Roblox Studio Integration\n`;
            code += `-- Este script pode criar/modificar mapas e jogos\n`;
            code += `local StudioMode = true\n`;
            code += `local function createPart(pos, size, color)\n`;
            code += `    local p = Instance.new("Part")\n`;
            code += `    p.Size = size or Vector3.new(4,1,2)\n`;
            code += `    p.Position = pos or Vector3.new(0,10,0)\n`;
            code += `    p.BrickColor = color or BrickColor.new("Bright red")\n`;
            code += `    p.Anchored = true\n`;
            code += `    p.Parent = Workspace\n`;
            code += `    return p\n`;
            code += `end\n`;
            code += `ExtTab:CreateButton("Criar Baseplate", function() createPart(Vector3.new(0,0,0), Vector3.new(100,1,100), BrickColor.new("Bright green")) end)\n`;
            code += `ExtTab:CreateButton("Criar Obby", function() for i=1,20 do createPart(Vector3.new(i*5, i*3, 0), Vector3.new(4,1,4), BrickColor.new("Bright blue")) end end)\n\n`;
            return code;
        }

        function generatePremiumScript() {
            const request = document.getElementById('premiumRequest').value;
            if (!request) {
                showToast('Descreva o que você quer!');
                return;
            }
            
            document.getElementById('loading').classList.add('active');
            
            setTimeout(() => {
                let code = generateOwnerLevelCode('PremiumScript', 'universal', request);
                showGeneratedCode('premium_script', code);
                document.getElementById('loading').classList.remove('active');
                showToast('🚀 Script Premium gerado!');
            }, 2000);
        }

        function generateOwnerScript() {
            const request = document.getElementById('ownerRequest').value;
            const complexity = document.getElementById('ownerComplexity').value;
            
            if (!request) {
                showToast('O que você quer criar, Dono?');
                return;
            }
            
            document.getElementById('loading').classList.add('active');
            
            setTimeout(() => {
                let code = `--[[\n`;
                code += `    ╔══════════════════════════════════════════╗\n`;
                code += `    ║     4XZYTT HUB - MODO DEUS ATIVADO       ║\n`;
                code += `    ║     Complexidade: ${complexity.toUpperCase()}                    ║\n`;
                code += `    ╚══════════════════════════════════════════╝\n`;
                code += `--]]\n\n`;
                
                code += generateOwnerLevelCode('GodModeScript', 'universal', request);
                
                if (complexity === 'god') {
                    code += `\n-- [GOD MODE EXTRAS]\n`;
                    code += `local function godMode() while true do task.wait() pcall(function() LocalPlayer.Character.Humanoid.Health = math.huge end) end end\n`;
                    code += `spawn(godMode)\n`;
                }
                
                showGeneratedCode('godmode_script', code);
                document.getElementById('loading').classList.remove('active');
                
                const count = parseInt(document.getElementById('ownerScriptsCount').textContent) + 1;
                document.getElementById('ownerScriptsCount').textContent = count;
                
                showToast('🔥 MODO DEUS: Script gerado com poder total!');
            }, 2500);
        }

        function showGeneratedCode(name, code) {
            document.getElementById('codeFilename').textContent = name + '.lua';
            document.getElementById('codeOutput').value = code;
            document.getElementById('codeContainer').classList.add('active');
        }

        function copyCode() {
            const textarea = document.getElementById('codeOutput');
            textarea.select();
            document.execCommand('copy');
            showToast('📋 Copiado!');
        }

        function downloadCode() {
            const code = document.getElementById('codeOutput').value;
            const name = document.getElementById('codeFilename').textContent;
            const blob = new Blob([code], {type: 'text/plain'});
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = name;
            a.click();
            URL.revokeObjectURL(url);
        }

        function saveToLibrary() {
            const script = {
                name: document.getElementById('codeFilename').textContent,
                code: document.getElementById('codeOutput').value,
                date: new Date().toLocaleString(),
                type: userType
            };
            
            savedScripts.unshift(script);
            localStorage.setItem('4xzytt_scripts', JSON.stringify(savedScripts));
            
            showToast('📚 Salvo na biblioteca!');
            loadSavedScripts();
        }

        function loadSavedScripts() {
            const list = document.getElementById('scriptsList');
            
            if (savedScripts.length === 0) {
                list.innerHTML = `
                    <div style="text-align: center; padding: 60px 20px; color: var(--text-muted);">
                        <div style="font-size: 3em; margin-bottom: 15px;">📭</div>
                        <p>Nenhum script salvo ainda.</p>
                        <p style="font-size: 0.9em; margin-top: 10px;">Gere seu primeiro script na aba "Gerador"!</p>
                    </div>
                `;
                return;
            }
            
            list.innerHTML = savedScripts.map((s, i) => `
                <div class="script-card">
                    <div class="script-info">
                        <h4>${s.name}</h4>
                        <p>${s.date} • ${s.type.toUpperCase()}</p>
                    </div>
                    <div class="script-actions">
                        <button class="code-btn" onclick="loadScriptFromLibrary(${i})">Carregar</button>
                        <button class="code-btn" onclick="deleteScriptFromLibrary(${i})">Excluir</button>
                    </div>
                </div>
            `).join('');
        }

        function loadScriptFromLibrary(index) {
            const s = savedScripts[index];
            document.getElementById('codeFilename').textContent = s.name;
            document.getElementById('codeOutput').value = s.code;
            document.getElementById('codeContainer').classList.add('active');
            showTab('generator');
            showToast('Script carregado!');
        }

        function deleteScriptFromLibrary(index) {
            savedScripts.splice(index, 1);
            localStorage.setItem('4xzytt_scripts', JSON.stringify(savedScripts));
            loadSavedScripts();
            showToast('Excluído!');
        }

        function copyPixCode() {
            const code = '00020101021126580014br.gov.bcb.pix013631f558f3-7b1d-478a-8d37-6462c49d836b5204000053039865802BR5917GUSTAVO M S SILVA6009ARAPIRACA62070503***630488A2';
            navigator.clipboard.writeText(code).then(() => {
                showToast('Chave Pix copiada!');
            });
        }

        function showTab(tab) {
            document.querySelectorAll('.menu-item').forEach(m => {
                m.classList.remove('active');
                m.classList.remove('owner-active');
            });
            
            const activeClass = userType === 'owner' ? 'owner-active' : 'active';
            document.getElementById('menu' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add(activeClass);
            
            document.getElementById('generatorTab').classList.add('hidden');
            document.getElementById('savedTab').classList.add('hidden');
            document.getElementById('premiumTab').classList.add('hidden');
            document.getElementById('ownerTab').classList.add('hidden');
            
            document.getElementById(tab + 'Tab').classList.remove('hidden');
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function logout() {
            localStorage.removeItem('4xzytt_user');
            localStorage.removeItem('4xzytt_user_type');
            location.reload();
        }

        function addPremiumKey(email, key) {
            premiumKeys.push({
                email: email,
                key: key || '4xzytt-' + Math.random().toString(36).substring(2, 10).toUpperCase(),
                created: new Date().toISOString()
            });
            localStorage.setItem('4xzytt_premium_keys', JSON.stringify(premiumKeys));
            return key;
        }

        function checkIfOwnerByKey() {
            const savedType = localStorage.getItem('4xzytt_user_type');
            return savedType === 'owner';
        }

        function exportData() {
            const data = {
                user: currentUser,
                scripts: savedScripts,
                premiumKeys: premiumKeys,
                exportDate: new Date().toISOString()
            };
            const blob = new Blob([JSON.stringify(data, null, 2)], {type: 'application/json'});
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = '4xzytt_backup_' + Date.now() + '.json';
            a.click();
        }

        function importData(jsonString) {
            try {
                const data = JSON.parse(jsonString);
                if (data.scripts) {
                    savedScripts = data.scripts;
                    localStorage.setItem('4xzytt_scripts', JSON.stringify(savedScripts));
                }
                if (data.premiumKeys) {
                    premiumKeys = data.premiumKeys;
                    localStorage.setItem('4xzytt_premium_keys', JSON.stringify(premiumKeys));
                }
                showToast('Dados importados!');
                loadSavedScripts();
            } catch (e) {
                showToast('Erro ao importar!');
            }
        }

        document.addEventListener('keydown', function(e) {
            if (userType === 'owner') {
                if (e.ctrlKey && e.shiftKey && e.key === 'D') {
                    e.preventDefault();
                    exportData();
                    showToast('💾 Backup exportado!');
                }
                
                if (e.ctrlKey && e.shiftKey && e.key === 'S') {
                    e.preventDefault();
                    showTab('owner');
                    document.getElementById('ownerRequest').focus();
                }
            }
        });

        setInterval(() => {
            if (currentUser && userType === 'owner') {
                if (Math.random() > 0.7) {
                    const current = parseInt(document.getElementById('todayScripts').textContent);
                    document.getElementById('todayScripts').textContent = current + 1;
                }
            }
        }, 10000);

        console.log('%c🔥 4XZYTT HUB CARREGADO 🔥', 'color: #ff0055; font-size: 20px; font-weight: bold;');
        console.log('%cModo: ' + (checkIfOwnerByKey() ? 'DONO 👑' : 'NORMAL'), 'color: #00ff88;');
    </script>
</body>
</html>
